# ================================================
# My Finance (My Finance) - Environment Variables
# Copy this file to .env and fill in the values
# ================================================

# ---- Backend ----
NODE_ENV=production

# PostgreSQL connection string (Neon)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Better Auth secret key (generate a strong random string)
SECRET_KEY=your-secret-key-here

# Base URL where the backend is accessible (no trailing slash)
BASE_URL=http://your-ec2-public-ip

# Port the backend listens on inside the container
PORT=8080

# Comma-separated list of allowed CORS origins
TRUSTED_ORIGINS=http://your-ec2-public-ip

# ---- Frontend ----
# URL the frontend uses to reach the backend (internal Docker network)
BACKEND_URL=http://backend:8080

# Public URL of the frontend
ORIGIN_URL=http://your-ec2-public-ip
